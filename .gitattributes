# Normalize line endings: store LF in the repo, regardless of OS / git config.
# Prevents noisy "whole file changed" diffs and CRLF/LF conflicts across machines.
* text=auto eol=lf

# Binary assets — never apply text/EOL conversion to these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.svg   text
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
